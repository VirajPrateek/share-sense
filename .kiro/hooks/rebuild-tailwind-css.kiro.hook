{
  "enabled": true,
  "name": "Rebuild Tailwind CSS",
  "description": "Automatically rebuilds the Tailwind CSS file when HTML templates are edited",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "sharesense/templates/*.html"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx tailwindcss -i sharesense/static/input.css -o sharesense/static/style.css --minify",
    "timeout": 30
  }
}